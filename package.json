{
  "name": "deep-playground-prototype",
  "version": "2016.3.10",
  "description": "",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "start": "npm run serve-watch",
    "prep": "copyfiles analytics.js index.html bilo.css dist && concat node_modules/material-design-lite/material.min.js node_modules/seedrandom/seedrandom.min.js > dist/lib.js",
    "build-css": "concat node_modules/material-design-lite/material.min.css styles.css > dist/bundle.css",
    "watch-css": "concat node_modules/material-design-lite/material.min.css styles.css -o dist/bundle.css",
    "build-html": "copyfiles index.html bilo.css dist",
    "watch-html": "copyfiles index.html dist",
    "build-bilo": "browserify src/bilo_playground.ts -p [tsify] -o dist/bilo.js",
    "watch-bilo": "watchify src/bilo_playground.ts -p [tsify] -v --debug -o dist/bilo.js",
    "test-bilo": "browserify src/bilo_test_runner.ts -p [tsify] -o dist/bilo_test.js && node dist/bilo_test.js",
    "write-bilo-snapshot": "browserify src/bilo_snapshot_entry.ts -p [tsify] -s biloSnapshot -o dist/bilo_snapshot.js && node scripts/write_bilo_snapshot.js",
    "build": "npm run prep  && npm run build-bilo && npm run build-css && npm run build-html",
    "copy-bilo-static": "copyfiles index.html bilo.css dist",
    "watch-bilo-static": "chokidar index.html bilo.css -c \"npm run copy-bilo-static\"",
    "watch": "npm run prep && concurrently \"npm run watch-bilo\" \"npm run watch-css\" \"npm run watch-html\" \"npm run watch-bilo-static\"",
    "serve": "npx serve dist/ -l 60806",
    "serve-watch": "concurrently \"npx serve dist/ -l 60806\" \"npm run watch\""
  },
  "devDependencies": {
    "@types/d3": "^3.5.34",
    "chokidar-cli": "^3.0.0",
    "concat": "^1.0.3",
    "concurrently": "3.1.0",
    "copyfiles": "1.0.0",
    "rimraf": "2.5.4",
    "serve": "^11.3.0",
    "terser": "^5.27.0",
    "tsify": "^4.0.0",
    "typescript": "^4.9",
    "watchify": "^4.0.0"
  },
  "dependencies": {
    "d3": "^3.5.16",
    "material-design-lite": "^1.3.0",
    "seedrandom": "^2.4.3"
  }
}
